# Copy this to .env and fill in your values
# Never commit .env to GitHub

# Your three wallet addresses on Ethereum Sepolia testnet
HOT_WALLET_ADDRESS=0xYourHotWalletAddress
WARM_WALLET_ADDRESS=0xYourWarmWalletAddress
COLD_WALLET_ADDRESS=0xYourColdWalletAddress

# Etherscan API key — free at etherscan.io/register
ETHERSCAN_API_KEY=YourEtherscanAPIKey

# Slack webhook URL — optional, alerts print to console if not set
# Create at api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
